// 输入科目信息
vector<Subject> inputSubjects() {
    vector<Subject> subjects;  //创建一个学生的科目数组 
    int subjectCount;
    
    cout << "请输入科目数量(3-5): ";
    cin >> subjectCount;
    
    while(subjectCount < 3 || subjectCount > 5) {
        cout << "科目数量必须在3-5之间，请重新输入: ";
        cin >> subjectCount;
    }
    
    for(int i = 0; i < subjectCount; i++) {
        Subject sub;   //实例化结构体科目对象 
        cout << "请输入第" << i+1 << "个科目名称: ";
        cin >> sub.name;
        cout << "请输入" << sub.name << "的成绩: ";
        cin >> sub.score;
        
        // 成绩验证
        while(sub.score < 0 || sub.score > 100) {
            cout << "成绩必须在0-100之间，请重新输入: ";
            cin >> sub.score;
        }
        
        subjects.push_back(sub); //将科目放进数组 
    }
    
    return subjects;  // 返回科目列表
}

// 打印单个考生信息
void printStudent(const Student& s) {
    cout << "准考证号: " << s.id << endl;
    cout << "姓    名: " << s.name << endl;
    cout << "性    别: " << s.gender << endl;
    cout << "年    龄: " << s.age << endl;
    cout << "科    目: " << endl;
    
    for(size_t i = 0; i < s.subjects.size(); i++) {
        cout << "  " << s.subjects[i].name << ": " << s.subjects[i].score << "分" << endl;
    }
    cout << "----------------------------------------" << endl;
}

// 检查准考证号是否已存在
bool isIdExist(string id, int excludeIndex) {
    for(size_t i = 0; i < students.size(); i++) {
        if(i != excludeIndex && students[i].id == id) {
            return true;
        }
    }
    return false;
}

// 1. 输入考生信息
void inputStudent() {
    Student s; //创建考生实例 
    
    cout << "========== 输入考生信息 ==========" << endl;
    
    // 输入准考证号并验证唯一性
    cout << "请输入准考证号: ";
    cin >> s.id;
    while(isIdExist(s.id)) {
        cout << "准考证号已存在，请重新输入: ";
        cin >> s.id;
    }
    
    cout << "请输入姓名: ";
    cin >> s.name;
    
    cout << "请输入性别(男/女): ";
    cin >> s.gender;
    
    cout << "请输入年龄: ";
    cin >> s.age;
    while(s.age < 0 || s.age > 120) {
        cout << "年龄无效，请重新输入(0-120): ";
        cin >> s.age;
    }
    
    // 直接接收返回的科目信息
    s.subjects = inputSubjects(); //return给学生自己的属性 
    
    students.push_back(s);  //再将一个学生放进学生数组 
    cout << "考生信息输入成功！" << endl;
}

